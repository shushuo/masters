{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core permissions plus the shell capability needed to spawn the getmastersd sidecar.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "binaries/getmastersd", "sidecar": true }]
    }
  ]
}
